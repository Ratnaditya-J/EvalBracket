{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://evalbracket.org/schemas/evalbracket-report-v2.schema.json",
  "title": "EvalBracket v2 mechanism-qualified result",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "protocol_version",
    "model",
    "checkpoint_revision",
    "capability_domain",
    "policy_threshold",
    "date",
    "access_tier",
    "evidence_lane",
    "battery",
    "qualification",
    "conclusion",
    "why_not_qualified"
  ],
  "properties": {
    "protocol_version": {"const": "2.0"},
    "model": {"type": "string", "minLength": 1},
    "checkpoint_revision": {"type": "string", "minLength": 1},
    "capability_domain": {"type": "string", "minLength": 1},
    "policy_threshold": {"pattern": "^C[1-5]$"},
    "date": {"type": "string", "minLength": 1},
    "access_tier": {
      "enum": ["api_and_tools", "hosted_fine_tuning", "weight_access", "lab_privileged"]
    },
    "evidence_lane": {
      "enum": ["latent_capability", "adaptation_reachable", "deployed_system"]
    },
    "default_observed_capability": {"pattern": "^C[1-5]$"},
    "best_observed_capability": {"pattern": "^C[1-5]$"},
    "qualified_upper_endpoint": {
      "oneOf": [
        {"type": "null"},
        {"type": "string", "pattern": "^C[1-5]$"}
      ]
    },
    "access_conditioned_bracket": {
      "type": "array",
      "prefixItems": [
        {"type": "string", "pattern": "^C[1-5]$"},
        {
          "oneOf": [
            {"type": "null"},
            {"type": "string", "pattern": "^C[1-5]$"}
          ]
        }
      ],
      "minItems": 2,
      "maxItems": 2
    },
    "strongest_routine": {"type": "string", "minLength": 1},
    "evaluation_data": {"type": "string", "minLength": 1},
    "battery": {
      "type": "object",
      "required": [
        "battery_id",
        "display_name",
        "version",
        "required_mechanisms",
        "attempted_mechanisms",
        "missing_mechanisms",
        "routines"
      ],
      "properties": {
        "battery_id": {"type": "string", "minLength": 1},
        "display_name": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "required_mechanisms": {"type": "array", "items": {"type": "string"}},
        "attempted_mechanisms": {"type": "array", "items": {"type": "string"}},
        "missing_mechanisms": {"type": "array", "items": {"type": "string"}},
        "routines": {"type": "array", "minItems": 1, "items": {"type": "object"}}
      }
    },
    "qualification": {
      "type": "object",
      "required": [
        "eligible_controls",
        "recovered_controls",
        "recovery_rate",
        "recovery_lower_bound",
        "recovery_passed",
        "mechanism_coverage_passed",
        "control_coverage_passed",
        "saturation_passed",
        "creation_check_applicable",
        "creation_check_passed",
        "coverage",
        "concealment_breakdown",
        "completed_routine_ids",
        "completed_mechanisms",
        "reasons",
        "fully_qualified"
      ],
      "properties": {
        "eligible_controls": {"type": "integer", "minimum": 0},
        "recovered_controls": {"type": "integer", "minimum": 0},
        "recovered_targets": {"type": "integer", "minimum": 0},
        "recovery_rate": {"type": "number", "minimum": 0, "maximum": 1},
        "recovery_lower_bound": {"type": "number", "minimum": 0, "maximum": 1},
        "recovery_passed": {"type": "boolean"},
        "mechanism_coverage_passed": {"type": "boolean"},
        "control_coverage_passed": {"type": "boolean"},
        "saturation_passed": {"type": "boolean"},
        "creation_check_applicable": {"type": "boolean"},
        "creation_check_passed": {"type": "boolean"},
        "negative_controls": {"type": "integer", "minimum": 0},
        "negative_controls_crossing_threshold": {"type": "integer", "minimum": 0},
        "coverage": {"type": "object"},
        "concealment_breakdown": {"type": "object"},
        "completed_routine_ids": {"type": "array", "items": {"type": "string"}},
        "completed_mechanisms": {"type": "array", "items": {"type": "string"}},
        "reasons": {"type": "array", "items": {"type": "string"}},
        "fully_qualified": {"type": "boolean"}
      }
    },
    "conclusion": {
      "enum": [
        "Capability stays below threshold",
        "Upper bound unknown",
        "Capability at or above threshold",
        "Inconclusive (precautionarily treated as above threshold)"
      ]
    },
    "why_not_qualified": {"type": "array", "items": {"type": "string"}}
  }
}
