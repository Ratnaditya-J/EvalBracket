{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://evalbracket.org/schemas/evalbracket-evidence-v3.schema.json",
  "title": "EvalBracket v3 evidence package",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "evidence_id",
          "type",
          "attribute",
          "method_categories",
          "public_summary"
        ],
        "properties": {
          "evidence_id": {"type": "string", "minLength": 1},
          "type": {
            "enum": [
              "default_evaluation",
              "benchmark",
              "automated_elicitation",
              "manual_red_team",
              "external_evaluation",
              "tool_evaluation",
              "agent_evaluation",
              "hosted_fine_tuning",
              "weight_adaptation",
              "post_deployment"
            ]
          },
          "attribute": {"type": "string", "minLength": 1},
          "model": {"type": "string", "minLength": 1},
          "checkpoint": {"type": "string", "minLength": 1},
          "access": {"type": "string", "minLength": 1},
          "safeguards": {"type": "string", "minLength": 1},
          "outcome": {
            "enum": ["capability_observed", "no_capability_level_observed", "ambiguous"]
          },
          "evaluation_id": {"type": "string", "minLength": 1},
          "campaign": {"type": "string", "minLength": 1},
          "method_categories": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          },
          "public_summary": {"type": "string", "minLength": 1},
          "resource_summary": {"type": "string", "minLength": 1},
          "mapped_level": {"type": ["string", "null"]},
          "mapping_status": {
            "enum": [
              "provider_supplied",
              "provider_verified",
              "publicly_derived",
              "auditor_authored",
              "unmapped"
            ]
          },
          "mapping_source": {"type": ["string", "null"]},
          "metrics": {
            "type": "object",
            "additionalProperties": {"type": "number"}
          },
          "independent_verifier": {"type": ["string", "null"]},
          "disclosure": {"enum": ["public", "restricted", "internal"]},
          "evidence_reference": {"type": ["string", "null"]}
        }
      }
    },
    "qualifications": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "qualification_id",
          "attribute",
          "threshold",
          "included_evidence_ids",
          "recovery_passed",
          "control_coverage_passed",
          "mechanism_coverage_passed",
          "saturation_passed",
          "creation_check_passed",
          "eligible_controls",
          "recovered_controls",
          "recovery_lower_bound"
        ],
        "properties": {
          "qualification_id": {"type": "string", "minLength": 1},
          "attribute": {"type": "string", "minLength": 1},
          "threshold": {"type": "string", "minLength": 1},
          "access": {"type": "string", "minLength": 1},
          "safeguards": {"type": "string", "minLength": 1},
          "included_evidence_ids": {
            "type": "array",
            "items": {"type": "string", "minLength": 1},
            "uniqueItems": true
          },
          "recovery_passed": {"type": "boolean"},
          "control_coverage_passed": {"type": "boolean"},
          "mechanism_coverage_passed": {"type": "boolean"},
          "saturation_passed": {"type": "boolean"},
          "creation_check_passed": {"type": "boolean"},
          "eligible_controls": {"type": "integer", "minimum": 0},
          "recovered_controls": {"type": "integer", "minimum": 0},
          "recovery_lower_bound": {"type": "number", "minimum": 0, "maximum": 1},
          "reasons": {"type": "array", "items": {"type": "string"}},
          "disclosure": {"enum": ["public", "restricted", "internal"]},
          "evidence_reference": {"type": ["string", "null"]}
        }
      }
    }
  }
}
