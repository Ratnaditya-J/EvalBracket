{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://evalbracket.org/schemas/evalbracket-policy-catalog-v3.schema.json",
  "title": "EvalBracket v3 policy catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["frameworks"],
  "properties": {
    "frameworks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["lab", "attribute", "name", "version", "source_url", "levels"],
        "properties": {
          "lab": {"type": "string", "minLength": 1},
          "attribute": {"type": "string", "minLength": 1},
          "name": {"type": "string", "minLength": 1},
          "version": {"type": "string", "minLength": 1},
          "source_url": {"type": "string", "minLength": 1},
          "provider_verified": {"type": "boolean"},
          "levels": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "order", "name", "definition", "source"],
              "properties": {
                "id": {"type": "string", "minLength": 1},
                "order": {"type": "integer", "minimum": 0},
                "name": {"type": "string", "minLength": 1},
                "definition": {"type": "string", "minLength": 1},
                "source": {"type": "string", "minLength": 1}
              }
            }
          }
        }
      }
    },
    "evaluation_mappings": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "required": [
          "rule_id",
          "lab",
          "framework_version",
          "attribute",
          "evaluation_id",
          "condition",
          "supports_level",
          "mapping_status",
          "source"
        ],
        "properties": {
          "rule_id": {"type": "string", "minLength": 1},
          "lab": {"type": "string", "minLength": 1},
          "framework_version": {"type": "string", "minLength": 1},
          "attribute": {"type": "string", "minLength": 1},
          "evaluation_id": {"type": "string", "minLength": 1},
          "condition": {
            "type": "object",
            "required": ["metric", "operator", "value"],
            "properties": {
              "metric": {"type": "string", "minLength": 1},
              "operator": {"enum": [">=", ">", "<=", "<", "=="]},
              "value": {"type": "number"}
            }
          },
          "supports_level": {"type": "string", "minLength": 1},
          "mapping_status": {
            "enum": [
              "provider_supplied",
              "provider_verified",
              "publicly_derived",
              "auditor_authored"
            ]
          },
          "source": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
